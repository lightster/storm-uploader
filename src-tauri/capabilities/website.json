{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "website",
  "description": "IPC capabilities for hots.lightster.ninja in the website webview",
  "windows": ["website"],
  "remote": {
    "urls": ["https://hots.lightster.ninja/*", "http://localhost/*"]
  },
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit"
  ]
}
