{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Storm Uploader",
  "version": "0.1.3",
  "identifier": "com.lightster.storm-uploader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
